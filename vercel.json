{
  "rewrites": [
    { "source": "/privacy", "destination": "/public/privacy.html" },
    { "source": "/app-ads.txt", "destination": "/public/app-ads.txt" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 16 * * 1,3,4,6"
    }
  ]
}
